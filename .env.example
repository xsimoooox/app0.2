# URL publique de l'app (domaine de production). Utilisée dans les QR codes et liens partagés.
# En local sur téléphone : http://192.168.x.x:5173
VITE_PUBLIC_APP_URL=

# Serveur Socket.io pour les appels Contacts (défaut : http://localhost:3001)
VITE_SOCKET_URL=http://localhost:3001

# Clés VAPID (générer : npx web-push generate-vapid-keys)
# À placer aussi dans un fichier .env à la racine pour server.cjs
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# PORT=3001
# WAKWAK_API_URL=http://localhost:3001
